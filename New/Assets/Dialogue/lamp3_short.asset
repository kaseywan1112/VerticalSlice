MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b1c3cae70ad8d9641a4b5be915b33736, type: 3}
  m_Name: lamp3_short
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Lamp
    portrait: {fileID: 21300000, guid: 1cf2efdbf19bab6468e7b31e8a9a4551, type: 3}
    text: Finally. A wise choice.
  - speakerName: Lamp
    portrait: {fileID: 21300000, guid: 61ce7f18f680f0d409ce1a814d48b7cf, type: 3}
    text: I was chilling in the river. Then some idiot threw a normal lamp into the
      water.
  - speakerName: Lamp
    portrait: {fileID: 21300000, guid: 88a417eae85a4f64c9a7057463b0cf71, type: 3}
    text: "A random glowing guy came out, grabbed me, and asked people, \u201CDid
      you drop this golden lamp? Or this silver lamp?\u201D"
  - speakerName: You
    portrait: {fileID: 21300000, guid: 787fafedeaa52fc4a96a9263c592c76e, type: 3}
    text: "Wait. Isn\u2019t that supposed to be an axe?"
  - speakerName: Lamp
    portrait: {fileID: 21300000, guid: 1cf2efdbf19bab6468e7b31e8a9a4551, type: 3}
    text: Exactly. Wrong object. Wrong story. Wrong victim.
  - speakerName: Lamp
    portrait: {fileID: 21300000, guid: f37d4b9411651a245acd90381f07228a, type: 3}
    text: Also, nobody asked if I wanted to be part of this.
  - speakerName: You
    portrait: {fileID: 21300000, guid: 139664e598056644193b46fd8e8d34e3, type: 3}
    text: So you ran away?
  - speakerName: Lamp
    portrait: {fileID: 21300000, guid: 4cc0f77cf054ed340b8f3f30720d91ce, type: 3}
    text: Yes. I have basic rights.
  options:
  - speakerName: 
    portrait: {fileID: 0}
    replyText: 
    nextNode: {fileID: 11400000, guid: 87ef24b53e784d4408dfe4ce287af48e, type: 2}
